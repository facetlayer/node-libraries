{
  "name": "@facetlayer/prism-framework-desktop",
  "version": "0.2.0",
  "description": "Electron desktop integration for Prism Framework applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "src/preload.cjs"
  ],
  "scripts": {
    "build": "tsc -p . && cp src/preload.cjs dist/preload.cjs",
    "dev": "tsc -p . --watch",
    "test": "vitest run",
    "typecheck": "tsc -p . --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "framework",
    "electron",
    "desktop",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "dependencies": {
    "@facetlayer/prism-framework": "workspace:*",
    "@facetlayer/streams": "workspace:*"
  },
  "peerDependencies": {
    "electron": ">=28.0.0",
    "zod": "^4.0.5"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^32.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0",
    "zod": "^4.1.12"
  }
}
