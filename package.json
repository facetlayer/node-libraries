{
  "name": "node-libraries",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r --filter '!*-docs' --filter '!*-docs-site' --filter '!*notesApp' --if-present build",
    "postinstall": "pnpm -r --filter '!*-docs' --filter '!*-docs-site' --filter '!*notesApp' --if-present --no-bail --reporter=append-only build || true"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/facetlayer/node-libraries"
  }
}
