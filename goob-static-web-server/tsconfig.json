{
  "include": [
    "src/**/*.ts"
  ],
  "compilerOptions": {
    "lib": [
      "es2021"
    ],
    "target": "es2022",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "node",
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "exclude": [
    "node_modules",
    "src/__tests__/**",
    "**/*.test.ts"
  ]
}
