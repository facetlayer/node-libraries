{
  "name": "@facetlayer/fl-sdlc",
  "version": "0.1.0",
  "description": "CLI tool for software development lifecycle management - branch management, PR management, and project guidelines",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fl-sdlc": "dist/cli.js"
  },
  "scripts": {
    "build": "node build.mts build",
    "prepublishOnly": "node build.mts validate && node build.mts build",
    "typecheck": "tsc -p .",
    "test": "vitest run",
    "local:install": "pnpm build && npm i -g ."
  },
  "keywords": [
    "sdlc",
    "git",
    "pr",
    "branch",
    "guidelines"
  ],
  "author": "andyfischer",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "files": [
    "src",
    "dist",
    "tsconfig.json",
    "README.md"
  ],
  "dependencies": {
    "@facetlayer/subprocess": "^1.1.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@facetlayer/build-config-nodejs": "0.3.1",
    "@types/node": "^22.10.2",
    "@types/yargs": "17.0.34",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
