      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.2",
    "better-sqlite3": "^12.8.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "19.2.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.2"
  }
